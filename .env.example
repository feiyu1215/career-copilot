# Career Copilot — LLM Provider 环境变量配置
#
# 复制此文件为 .env 并填写你的配置：
#   cp .env.example .env
#
# 然后根据你使用的 Provider 填写对应值。

# ──────────────────────────────────────────────
# Provider 选择（internal 或 external）
# ──────────────────────────────────────────────
LLM_PROVIDER=internal

# ──────────────────────────────────────────────
# Provider: internal（OpenAI 兼容接口）
# ──────────────────────────────────────────────
LLM_BASE_URL=https://your-openai-compatible-endpoint.com/v1
LLM_API_KEY=your-api-key-here

# ──────────────────────────────────────────────
# Provider: external（外部 API 代理）
# ──────────────────────────────────────────────
EXTERNAL_BASE_URL=https://your-external-endpoint.com/v1
EXTERNAL_API_KEY=sk-your-api-key-here

# ──────────────────────────────────────────────
# 可选：career_log.py 存储路径（默认 ~/.catpaw/career-copilot）
# ──────────────────────────────────────────────
# CAREER_COPILOT_DIR=~/.catpaw/career-copilot
